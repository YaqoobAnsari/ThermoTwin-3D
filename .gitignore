# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/local/
.python-version

# ---- Tooling caches ----
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/
.coverage
htmlcov/

# ---- Secrets / local config ----
.env
*.local.yaml

# ---- Heavy data & artefacts (keep .gitkeep and *.md) ----
*.ply
*.las
*.laz
*.e57
*.pcd
*.h5
*.hdf5
*.npz
*.npy
*.pt
*.pth
*.ckpt
*.onnx
*.vtu
