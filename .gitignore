*.obj
*.stl
*.glb
*.idf
*.epw
*.tif
*.tiff

# ---- Datasets: ignore all blobs under data/, keep only structure + provenance ----
# (belt-and-braces with the extension list above; see docs/datasets.md)
/data/**
!/data/**/
!/data/**/.gitkeep
!/data/**/SOURCE.md

# ---- Vendored third-party baseline code (fetched by scripts/fetch_baselines.sh) ----
vendored/

# ---- Experiment outputs ----
results/*
!results/README.md
!results/.gitkeep
!results/logs/.gitkeep
outputs/
multirun/
.hydra/
wandb/
*.log

# ---- OS / IDE ----
.DS_Store
.idea/
*.swp
